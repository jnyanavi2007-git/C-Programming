#include <stdio.h>

int main() {
    int age;
    char citizen;

    printf("Enter age: ");
    scanf("%d", &age);

    if (age >= 18) {
        printf("Are you an Indian citizen? (Y/N): ");
        scanf(" %c", &citizen);

        if (citizen == 'Y' || citizen == 'y')
            printf("Eligible to vote.\n");
        else
            printf("Not eligible (Not a citizen).\n");
    } else {
        printf("Not eligible to vote.\n");
    }

    return 0;
}

Output:
Enter age: 20
Are you an Indian citizen? (Y/N): Y
Eligible to vote.

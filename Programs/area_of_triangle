/*
Program: area_of_triangle.c
Purpose: Calculate the area of a triangle.
*/

#include <stdio.h>

int main() {
    float b, h, area;

    printf("Enter the base of the triangle: ");
    scanf("%f", &b);

    printf("Enter the height of the triangle: ");
    scanf("%f", &h);

    area = 0.5 * b * h;

    printf("Area of the triangle = %.2f\n", area);

    return 0;
}

